# Copy to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Kafka
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=creditcard.transactions

# PostgreSQL (TimescaleDB)
POSTGRES_URL=postgresql://fraud:fraud@postgres:5432/frauddb

# Redis
REDIS_URL=redis://redis:6379

# Producer
STREAM_INTERVAL_MS=2000
PRODUCER_MODE=kaggle        # live | replay | kaggle

# Consumer
MODEL_PATH=/app/models/xgb_fraud.json
CHECKPOINT_DIR=/tmp/spark_checkpoints

# Dashboard (Vite)
VITE_API_URL=http://localhost:8000
